# Kernel config fragment for QEMU x86_64 boot
# Merge on top of: make defconfig + ci/kernel.config.fragment
#
# Usage:
#   scripts/kconfig/merge_config.sh -m .config \
#     ci/kernel.config.fragment \
#     ci/qemu/kernel-qemu.config

# --- QEMU boot essentials ---
CONFIG_64BIT=y
CONFIG_X86_64=y
CONFIG_SMP=y
CONFIG_NR_CPUS=4
CONFIG_HYPERVISOR_GUEST=y
CONFIG_PARAVIRT=y
CONFIG_KVM_GUEST=y

# --- Storage & Filesystem for ext4 rootfs image ---
CONFIG_BLK_DEV_SD=y
CONFIG_SCSI=y
CONFIG_SCSI_LOWLEVEL=y
CONFIG_SCSI_VIRTIO=y
CONFIG_VIRTIO_BLK=y
CONFIG_VIRTIO_PCI=y
CONFIG_EXT4_FS=y
CONFIG_EXT4_USE_FOR_EXT2=y

# --- Serial console (QEMU uses ttyS0) ---
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
CONFIG_TTY=y
CONFIG_VT=y
CONFIG_VT_CONSOLE=y

# --- Network (virtio-net for QEMU) ---
CONFIG_NET=y
CONFIG_INET=y
CONFIG_VIRTIO_NET=y
CONFIG_PACKET=y
CONFIG_UNIX=y

# --- Pseudo filesystems ---
CONFIG_PROC_FS=y
CONFIG_PROC_SYSCTL=y
CONFIG_SYSFS=y
CONFIG_TMPFS=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y

# --- Basic system ---
CONFIG_BINFMT_ELF=y
CONFIG_BINFMT_SCRIPT=y
CONFIG_CGROUPS=y
CONFIG_NAMESPACES=y
CONFIG_NET_NS=y

# --- Necessary for test tools ---
CONFIG_NETFILTER=y
CONFIG_NETFILTER_ADVANCED=y
CONFIG_NF_CONNTRACK=y
CONFIG_NF_NAT=y
CONFIG_IP_NF_IPTABLES=y

# --- Debug (optional but useful) ---
CONFIG_PRINTK=y
CONFIG_PRINTK_TIME=y
CONFIG_EARLY_PRINTK=y
