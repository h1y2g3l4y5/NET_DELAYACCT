Add CONFIG_NET_DELAYACCT field to struct sock.

Embeds struct net_delayacct into struct sock, #ifdef-protected so
kernels without the option see no ABI change or memory growth.
The per-socket spinlock is independent of sk->sk_lock.slock to avoid
lock-ordering issues with the socket lock taken in RX/TX paths.

Applies to Linux 6.6 (linux-6.6.y).

--- a/include/net/sock.h
+++ b/include/net/sock.h
@@ -66,6 +66,7 @@
 #include <net/dst.h>
 #include <net/checksum.h>
 #include <net/tcp_states.h>
+#include <net/net-delayacct.h>
 #include <linux/net_tstamp.h>
 #include <net/l3mdev.h>
 #include <uapi/linux/socket.h>
@@ -434,6 +435,9 @@
 	int			sk_disconnects;
 
 	struct sk_filter __rcu	*sk_filter;
+#ifdef CONFIG_NET_DELAYACCT
+	struct net_delayacct	sk_net_delayacct;
+#endif
 	union {
 		struct socket_wq __rcu	*sk_wq;
 		/* private: */
