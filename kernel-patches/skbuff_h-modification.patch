Add per-skb delayacct_start timestamp to struct sk_buff.

Carries the start-of-delay timestamp from protocol-stack entry
through to the RX/TX accounting end point. #ifdef-protected so
kernels without CONFIG_NET_DELAYACCT see no growth in struct sk_buff.

Applies to Linux 6.6 (linux-6.6.y).

--- a/include/linux/skbuff.h
+++ b/include/linux/skbuff.h
@@ -867,6 +867,11 @@
 		ktime_t		tstamp;
 		u64		skb_mstamp_ns; /* earliest departure time */
 	};
+
+#ifdef CONFIG_NET_DELAYACCT
+	/* start time for net-delayacct, in ns; 0 = not stamped */
+	__u64			delayacct_start;
+#endif
 	/*
 	 * This is the control buffer. It is free to use for every
 	 * layer. Please put your private variables there. If you
