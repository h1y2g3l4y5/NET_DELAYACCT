TX path instrumentation for CONFIG_NET_DELAYACCT.

Stamps skb->delayacct_start when a new skb is allocated in
tcp_sendmsg_locked()/udp_sendmsg() and accumulates per-socket TX
latency in dev_hard_start_xmit() before the driver xmit callback.

Applies to Linux 6.6 (linux-6.6.y). Apply after rx-instrumentation
patch (which adds the include to dev.c/tcp.c/udp.c).

--- a/net/ipv4/tcp.c
+++ b/net/ipv4/tcp.c
@@ -1166,6 +1166,7 @@
 			skb->decrypted = !!(flags & MSG_SENDPAGE_DECRYPTED);
 #endif
 			tcp_skb_entail(sk, skb);
+			net_delayacct_tx_start(skb);
 			copy = size_goal;
 
 			/* All packets are restored as if they have
--- a/net/ipv4/udp.c
+++ b/net/ipv4/udp.c
@@ -1266,8 +1266,10 @@
 				  sizeof(struct udphdr), &ipc, &rt,
 				  &cork, msg->msg_flags);
 		err = PTR_ERR(skb);
-		if (!IS_ERR_OR_NULL(skb))
+		if (!IS_ERR_OR_NULL(skb)) {
+			net_delayacct_tx_start(skb);
 			err = udp_send_skb(skb, fl4, &cork);
+		}
 		goto out;
 	}
 
