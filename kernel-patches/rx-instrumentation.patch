RX path instrumentation for CONFIG_NET_DELAYACCT.

Stamps skb->delayacct_start at __netif_receive_skb_core() entry and
accumulates per-socket RX latency in tcp_recvmsg()/udp_recvmsg()
before the payload is copied to user space.

Applies to Linux 6.6 (linux-6.6.y). Apply after sock_h and skbuff_h
patches.

--- a/net/core/dev.c
+++ b/net/core/dev.c
@@ -101,6 +101,7 @@
 #include <linux/stat.h>
 #include <net/dsa.h>
 #include <net/dst.h>
+#include <net/net-delayacct.h>
 #include <net/dst_metadata.h>
 #include <net/gro.h>
 #include <net/pkt_sched.h>
@@ -5446,6 +5447,8 @@
 
 	trace_netif_receive_skb(skb);
 
+	net_delayacct_rx_start(skb);
+
 	orig_dev = skb->dev;
 
 	skb_reset_network_header(skb);
--- a/net/ipv4/tcp.c
+++ b/net/ipv4/tcp.c
@@ -272,6 +272,7 @@
 #include <net/icmp.h>
 #include <net/inet_common.h>
 #include <net/tcp.h>
+#include <net/net-delayacct.h>
 #include <net/mptcp.h>
 #include <net/xfrm.h>
 #include <net/ip.h>
@@ -2504,6 +2505,7 @@
 
 found_ok_skb:
 		/* Ok so how much can we use? */
+		net_delayacct_rx_end(sk, skb);
 		used = skb->len - offset;
 		if (len < used)
 			used = len;
--- a/net/ipv4/udp.c
+++ b/net/ipv4/udp.c
@@ -105,6 +105,7 @@
 #include <net/checksum.h>
 #include <net/gso.h>
 #include <net/xfrm.h>
+#include <net/net-delayacct.h>
 #include <trace/events/udp.h>
 #include <linux/static_key.h>
 #include <linux/btf_ids.h>
@@ -1838,6 +1839,8 @@
 	if (!skb)
 		return err;
 
+	net_delayacct_rx_end(sk, skb);
+
 	ulen = udp_skb_len(skb);
 	copied = len;
 	if (copied > ulen - off)
